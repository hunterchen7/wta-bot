{
  "name": "wta-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:web && wrangler dev",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "deploy": "npm run build:web && wrangler deploy",
    "deploy:ci": "wrangler d1 migrations apply wta-bot --remote && npm run build:web && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "register": "node --env-file=.dev.vars scripts/register-commands.ts",
    "migrate:local": "wrangler d1 migrations apply wta-bot --local",
    "migrate:remote": "wrangler d1 migrations apply wta-bot --remote"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.8.0",
    "lucide-react": "^1.24.0",
    "mediabunny": "^1.50.8",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260708.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
