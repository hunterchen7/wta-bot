{
  "name": "wta-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:web && wrangler dev",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "deploy": "npm run build:web && wrangler deploy",
    "deploy:ci": "wrangler d1 migrations apply wta-bot --remote && npm run build:web && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "register": "node --env-file=.dev.vars scripts/register-commands.ts",
    "migrate:local": "wrangler d1 migrations apply wta-bot --local",
    "migrate:remote": "wrangler d1 migrations apply wta-bot --remote"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "hono": "^4.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260708.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
