# Copy to .dev.vars (gitignored) and fill in.
# Production equivalents are set with: wrangler secret put <NAME>

# From https://discord.com/developers/applications -> your app
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
# Bot tab -> Reset Token
DISCORD_TOKEN=
# Right-click your dev server -> Copy Server ID (enable Developer Mode in Discord settings)
DEV_GUILD_ID=

# openssl rand -hex 32
FORM_SIGNING_SECRET=

# Comma-separated guild ids the bot serves (the app is public on Discord's
# side; this is the real gate). Unset = allow all, for pre-setup only.
# Set to your dev guild locally; dev+prod guild ids in production.
ALLOWED_GUILD_IDS=
